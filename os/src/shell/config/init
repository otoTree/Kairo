#!/bin/sh
# Kairo Desktop Environment Init Script
# 启动桌面环境：壁纸 → 任务栏 → WM → 内核

# --- 环境变量 ---
export PATH="/usr/local/bin:$PATH"
export PYTHON_ENV_PATH="$HOME/.kairo/python_env"

# --- D-Bus（waybar 等 GTK 应用依赖） ---
if ! pgrep -x dbus-daemon >/dev/null 2>&1; then
  sudo rc-service dbus start 2>/dev/null || true
fi
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/dbus/system_bus_socket"

# --- 壁纸 (swaybg, background 层) ---
swaybg -c '#0d0d12' &

# --- 任务栏 (waybar, bottom 层) ---
waybar &

# --- 窗口管理器 ---
kairo-wm > /tmp/kairo-wm.log 2>&1 &
sleep 1

# --- Kairo 内核（仅管理 Agent 窗口和 KDP） ---
if command -v kairo-kernel >/dev/null 2>&1; then
  kairo-kernel > /tmp/kairo-kernel.log 2>&1 &
  sleep 1
fi

# --- 快捷键绑定（通过 riverctl，如果可用） ---
if command -v riverctl >/dev/null 2>&1; then
  riverctl map normal Super Return spawn foot
  riverctl map normal Super+Shift Return spawn "chromium-browser --no-sandbox --ozone-platform=wayland --enable-features=UseOzonePlatform"
  riverctl map normal Super D spawn fuzzel
  riverctl map normal Super E spawn thunar
  riverctl map normal Super Q close
  riverctl map normal Super F toggle-fullscreen
  riverctl map normal Alt Tab focus-view next
  riverctl map normal Alt+Shift Tab focus-view previous
fi

# --- 布局（kairo-wm 内置 Master-Stack 布局，rivertile 可选） ---
if command -v rivertile >/dev/null 2>&1; then
  riverctl default-layout rivertile
  rivertile -view-padding 4 -outer-padding 4 &
fi

# --- 回退：仅在内核崩溃时打开终端供调试 ---
if command -v kairo-kernel >/dev/null 2>&1; then
  # 监控内核进程，崩溃时打开终端
  (while true; do
    if ! pgrep -f "kairo-kernel" >/dev/null 2>&1; then
      foot &
      break
    fi
    sleep 5
  done) &
fi
